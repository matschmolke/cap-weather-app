{
  "name": "weather",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0",
    "@sap-cloud-sdk/connectivity": "^4.5.1",
    "@sap-cloud-sdk/http-client": "^4.5.1"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-weather-app": "cds watch --open weatherapp/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/weather-app"
  ],
  "cds": {
    "requires": {
      "weather": {
        "kind": "rest",
        "credentials": {
          "destination": "weather"
        }
      }
    }
  }
}