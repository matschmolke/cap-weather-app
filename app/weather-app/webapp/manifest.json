{
  "_version": "1.83.0",
  "sap.app": {
    "id": "weatherapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "16a20f96-cd80-4267-bd03-32046b308480"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/weather/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "weatherapp.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "VoivodeshipsList",
          "target": "VoivodeshipsList"
        },
        {
          "pattern": "Voivodeships({key}):?query:",
          "name": "VoivodeshipsObjectPage",
          "target": "VoivodeshipsObjectPage"
        },
        {
          "name": "Voivodeships_CitiesObjectPage",
          "pattern": "Voivodeships({key})/Cities({CitiesKey}):?query:",
          "target": "Voivodeships_CitiesObjectPage"
        },
        {
          "name": "Voivodeships_Cities_TemperaturesObjectPage",
          "pattern": "Voivodeships({key})/Cities({CitiesKey})/Temperatures({TemperaturesKey}):?query:",
          "target": "Voivodeships_Cities_TemperaturesObjectPage"
        }
      ],
      "targets": {
        "VoivodeshipsList": {
          "type": "Component",
          "id": "VoivodeshipsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Voivodeships",
              "variantManagement": "Page",
              "navigation": {
                "Voivodeships": {
                  "detail": {
                    "route": "VoivodeshipsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "VoivodeshipsObjectPage": {
          "type": "Component",
          "id": "VoivodeshipsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Voivodeships",
              "navigation": {
                "Cities": {
                  "detail": {
                    "route": "Voivodeships_CitiesObjectPage"
                  }
                }
              }
            }
          }
        },
        "Voivodeships_CitiesObjectPage": {
          "type": "Component",
          "id": "Voivodeships_CitiesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {
                "Temperatures": {
                  "detail": {
                    "route": "Voivodeships_Cities_TemperaturesObjectPage"
                  }
                }
              },
              "contextPath": "/Voivodeships/Cities"
            }
          }
        },
        "Voivodeships_Cities_TemperaturesObjectPage": {
          "type": "Component",
          "id": "Voivodeships_Cities_TemperaturesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "navigation": {},
              "contextPath": "/Voivodeships/Cities/Temperatures"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
